{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "FirstSalary Quest",
  "version": "0.1.0",
  "identifier": "org.initcron.firstsalaryquest",
  "build": {
    "frontendDist": "../build",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FirstSalary Quest",
        "width": 1100,
        "height": 740,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Education",
    "shortDescription": "Educational financial-literacy simulator",
    "longDescription": "FirstSalary Quest is a gamified 12-month salary simulation that teaches first-time earners core money concepts. Educational simulator only — not a financial advisory app.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
